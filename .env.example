# ========== 数据库 ==========
# 可选：应用版本号。生产环境通常通过 APP_VERSION=... docker compose ... --build 注入。
# APP_VERSION=dev
# SQLAlchemy 形式的 PostgreSQL 连接串（驱动使用 psycopg v3）
DATABASE_URL=postgresql+psycopg://tm_user:tm123456@localhost:5432/tm_demo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=60
DATABASE_POOL_RECYCLE=1800
TERM_IMPORT_PREVIEW_MAX_SCAN_ROWS=5000
RESOURCE_IMPORT_PREVIEW_MAX_SCAN_ROWS=1000
RESOURCE_IMPORT_BATCH_SIZE=1000
RESOURCE_IMPORT_MAX_SIZE_MB=1024

# ========== 缓存（可选） ==========
# 若未配置 REDIS_URL，缓存将自动回退到进程内存
REDIS_URL=redis://127.0.0.1:6379/0

# ========== 导入队列 ==========
# local：由 FastAPI 后台任务处理；arq：投递到 Redis，需要另行启动 ARQ worker
IMPORT_QUEUE_BACKEND=local

# ========== Word 文档统计（可选） ==========
# 配置 Aspose.Words 许可证后，DOCX 页数/字数/字符数统计会标记为 licensed。
ASPOSE_WORDS_LICENSE_PATH=
LIBREOFFICE_SOFFICE_PATH=
LIBREOFFICE_PYTHON_PATH=
LIBREOFFICE_TIMEOUT_SECONDS=60

# ========== TM 向量检索 ==========
TM_VECTOR_ENABLED=true
TM_VECTOR_DIMENSIONS=128
TM_VECTOR_CANDIDATE_LIMIT=6
TM_VECTOR_SIMILARITY_FLOOR=0.45
TM_VECTOR_WEIGHT=0.35

# ========== LLM 服务 ==========
# 至少配置一个 provider，否则 LLM 修正功能不可用
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 可选示例：google/gemini-3.5-flash、google/gemini-3.1-pro-preview、openai/gpt-5.4、openai/gpt-5.4-mini
OPENROUTER_MODEL=google/gemini-3.5-flash

LLM_TIMEOUT_SECONDS=60
LLM_STALL_TIMEOUT_SECONDS=120
LLM_MAX_CONCURRENCY=20
LLM_TEMPERATURE=0.2
LLM_RETRY_ATTEMPTS_PER_PROVIDER=2

# ========== LanguageTool 拼写/语法 QA（可选） ==========
# 建议仅在内网部署自托管 LanguageTool，不调用公开云 API
LANGUAGETOOL_BASE_URL=http://languagetool:8010/v2
LANGUAGETOOL_TIMEOUT_SECONDS=10
LANGUAGETOOL_MAX_TEXT_LENGTH=20000

# ========== 认证 ==========
# 务必替换为一段足够长的随机字符串，否则后端会拒绝启动
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ========== 文件上传 / 存储 ==========
FILE_STORAGE_DIR=data/file_records
EXPORT_TASK_DIR=data/export_tasks
IMPORT_TASK_DIR=data/import_tasks
IMPORT_TASK_STAGING_TTL_SECONDS=86400
UPLOAD_MAX_SIZE_MB=100
UPLOAD_MAX_FILES_PER_BATCH=50
UPLOAD_MAX_TOTAL_SIZE_MB=500
UPLOAD_MAX_EXPANDED_FILES=100
DEFAULT_SIMILARITY_THRESHOLD=0.60

# ========== 日志 ==========
LOG_LEVEL=INFO
