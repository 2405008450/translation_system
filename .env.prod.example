# Docker Compose 会把本文件复制为 .env.prod 使用。
# 生产环境请替换所有 change-me，并且不要提交 .env.prod。

# ========== Docker / PostgreSQL ==========
TZ=Asia/Shanghai
POSTGRES_DB=tm_demo
POSTGRES_USER=tm_user
POSTGRES_PASSWORD=change-me-postgres-password

# 密码里如果包含 @ : / ? # 等 URL 特殊字符，请在 DATABASE_URL 中做 URL 编码。
DATABASE_URL=postgresql+psycopg://tm_user:change-me-postgres-password@postgres:5432/tm_demo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=60
DATABASE_POOL_RECYCLE=1800

# ========== Redis / 队列 ==========
REDIS_URL=redis://redis:6379/0
IMPORT_QUEUE_BACKEND=arq

# ========== 文件处理 ==========
FILE_STORAGE_DIR=/app/data/file_records
EXPORT_TASK_DIR=/app/data/export_tasks
UPLOAD_MAX_SIZE_MB=100
LIBREOFFICE_SOFFICE_PATH=/usr/bin/libreoffice
LIBREOFFICE_PYTHON_PATH=/usr/bin/python3
LIBREOFFICE_TIMEOUT_SECONDS=60
ASPOSE_WORDS_LICENSE_PATH=

# ========== TM 向量检索 ==========
TM_VECTOR_ENABLED=true
TM_VECTOR_DIMENSIONS=128
TM_VECTOR_CANDIDATE_LIMIT=6
TM_VECTOR_SIMILARITY_FLOOR=0.45
TM_VECTOR_WEIGHT=0.35

# ========== LLM 服务 ==========
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.5-flash

REFERENCE_LLM_API_KEY=
REFERENCE_LLM_BASE_URL=https://openrouter.ai/api/v1
REFERENCE_LLM_MODEL=google/gemini-3.5-flash

LLM_TIMEOUT_SECONDS=60
LLM_STALL_TIMEOUT_SECONDS=120
LLM_MAX_CONCURRENCY=5
LLM_TEMPERATURE=0.2
LLM_RETRY_ATTEMPTS_PER_PROVIDER=2

# ========== 可选：项目内 Mihomo/Clash 代理 ==========
# 推荐使用 docker-compose.proxy.yml 启用代理；该 override 文件会只给 app/worker 注入代理变量。
# 如果你另行提供同名 Mihomo 服务，也可以把下面的变量复制到 .env.prod 并取消注释。
# HTTP_PROXY=http://mihomo:7890
# HTTPS_PROXY=http://mihomo:7890
# ALL_PROXY=http://mihomo:7890
# http_proxy=http://mihomo:7890
# https_proxy=http://mihomo:7890
# all_proxy=http://mihomo:7890
# NO_PROXY=localhost,127.0.0.1,::1,postgres,redis,languagetool,ai-translation-postgres,ai-translation-redis,ai-translation-languagetool
# no_proxy=localhost,127.0.0.1,::1,postgres,redis,languagetool,ai-translation-postgres,ai-translation-redis,ai-translation-languagetool

# ========== LanguageTool ==========
LANGUAGETOOL_BASE_URL=http://languagetool:8010/v2
LANGUAGETOOL_TIMEOUT_SECONDS=10
LANGUAGETOOL_MAX_TEXT_LENGTH=20000

# ========== 认证 / 日志 ==========
JWT_SECRET_KEY=change-me-random-long-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
LOG_LEVEL=INFO

# 前后端同源访问时 CORS 不参与；保留该项用于直接调 API 或未来接入反代。
CORS_ALLOW_ORIGINS=["http://43.132.156.72:19013","http://127.0.0.1:19013","http://localhost:19013"]
