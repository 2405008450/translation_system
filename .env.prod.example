# Docker Compose 会把本文件复制为 .env.prod 使用。
# 生产环境请替换所有 change-me，并且不要提交 .env.prod。
#
# 与 .env 的关系：生产上以 .env.prod 为准；若用独立版 docker-compose 且不想每次
# 写 --env-file，可执行 cp .env.prod .env 保持两份内容一致（见 DEPLOYMENT_DOCKER.md）。

# ========== Docker / PostgreSQL ==========
TZ=Asia/Shanghai
POSTGRES_DB=tm_demo
POSTGRES_USER=tm_user
POSTGRES_PASSWORD=change-me-postgres-password

# 密码里如果包含 @ : / ? # 等 URL 特殊字符，请在 DATABASE_URL 中做 URL 编码。
# 默认经由 PgBouncer(6432) 访问数据库；如需直连 Postgres 改回 @postgres:5432 并关闭下方事务池化开关。
DATABASE_URL=postgresql+psycopg://tm_user:change-me-postgres-password@pgbouncer:6432/tm_demo
# 经由 PgBouncer 的 transaction 池化访问时必须置为 true（关闭服务端预备语句）。
DATABASE_PGBOUNCER_TRANSACTION_MODE=true
# 写入连接的 application_name，便于在 pg_stat_activity 中区分 web/worker 来源。
DATABASE_APPLICATION_NAME=ai-translation-web
# 接入 PgBouncer 后由中间件统一做连接复用，每个进程的连接池可调小；
# 总后端连接 ≈ worker 数 x POOL_SIZE，请与 PgBouncer DEFAULT_POOL_SIZE 及 Postgres max_connections 协调。
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
# 连接获取超时调小，让请求快速失败由前端重试，避免长时间卡死。
DATABASE_POOL_TIMEOUT=15
DATABASE_POOL_RECYCLE=1800
# 同步接口/后台任务的线程池大小（留空使用 anyio 默认 40）。建议与每进程连接池容量及
# PgBouncer 池大小协调，避免线程数远超可用连接导致排队。
# SERVER_THREADPOOL_SIZE=40
TERM_IMPORT_PREVIEW_MAX_SCAN_ROWS=5000
RESOURCE_IMPORT_PREVIEW_MAX_SCAN_ROWS=1000
RESOURCE_IMPORT_BATCH_SIZE=1000

# ========== 对外端口（Compose 注入 nginx / app） ==========
# 默认方案 A：不启 nginx，公网访问 app 映射端口（安全组放行 APP_PUBLISH_PORT）。
# 待 80 端口空闲后，可用 USE_NGINX=1 启用 nginx（见 DEPLOYMENT_DOCKER.md）。
NGINX_HTTP_PORT=80
APP_PUBLISH_PORT=19013

# ========== Redis / 队列 ==========
REDIS_URL=redis://redis:6379/0
IMPORT_QUEUE_BACKEND=arq

# ========== 文件存储 / 上传限制 ==========
FILE_STORAGE_DIR=/app/data/file_records
EXPORT_TASK_DIR=/app/data/export_tasks
IMPORT_TASK_DIR=/app/data/import_tasks
IMPORT_TASK_STAGING_TTL_SECONDS=86400
# 单文件 fallback（实际按格式 adapter 限制，如 pdf/pptx 100MB）；应与 nginx client_max_body_size 协调。
UPLOAD_MAX_SIZE_MB=100
UPLOAD_MAX_FILES_PER_BATCH=50
UPLOAD_MAX_TOTAL_SIZE_MB=500
UPLOAD_MAX_EXPANDED_FILES=100
# 大文件 multipart 上传可能超过默认 120s，生产建议 600。
GUNICORN_TIMEOUT=600
LIBREOFFICE_SOFFICE_PATH=/usr/bin/libreoffice
LIBREOFFICE_PYTHON_PATH=/usr/bin/python3
LIBREOFFICE_TIMEOUT_SECONDS=60
ASPOSE_WORDS_LICENSE_PATH=

# ========== TM 向量检索 ==========
TM_VECTOR_ENABLED=true
TM_VECTOR_DIMENSIONS=128
TM_VECTOR_CANDIDATE_LIMIT=6
TM_VECTOR_SIMILARITY_FLOOR=0.45
TM_VECTOR_WEIGHT=0.35

# ========== LLM 服务 ==========
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.5-flash

REFERENCE_LLM_API_KEY=
REFERENCE_LLM_BASE_URL=https://openrouter.ai/api/v1
REFERENCE_LLM_MODEL=google/gemini-3.5-flash

LLM_TIMEOUT_SECONDS=60
LLM_STALL_TIMEOUT_SECONDS=120
LLM_MAX_CONCURRENCY=5
LLM_TEMPERATURE=0.2
LLM_RETRY_ATTEMPTS_PER_PROVIDER=2

# ========== 可选：项目内 Mihomo/Clash 代理 ==========
# 推荐使用 docker-compose.proxy.yml 启用代理（scripts/deploy_prod.sh USE_PROXY=1）；
# 若自行提供 Mihomo 服务，可取消下面注释。
# HTTP_PROXY=http://mihomo:7890
# HTTPS_PROXY=http://mihomo:7890
# ALL_PROXY=http://mihomo:7890
# http_proxy=http://mihomo:7890
# https_proxy=http://mihomo:7890
# all_proxy=http://mihomo:7890
# NO_PROXY=localhost,127.0.0.1,::1,postgres,redis,languagetool,pgbouncer,mihomo,app,nginx,ai-translation-postgres,ai-translation-redis,ai-translation-languagetool,ai-translation-app,ai-translation-nginx
# no_proxy=localhost,127.0.0.1,::1,postgres,redis,languagetool,pgbouncer,mihomo,app,nginx,ai-translation-postgres,ai-translation-redis,ai-translation-languagetool,ai-translation-app,ai-translation-nginx

# ========== LanguageTool ==========
LANGUAGETOOL_BASE_URL=http://languagetool:8010/v2
LANGUAGETOOL_TIMEOUT_SECONDS=10
LANGUAGETOOL_MAX_TEXT_LENGTH=20000

# ========== 认证 / 日志 ==========
JWT_SECRET_KEY=change-me-random-long-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
LOG_LEVEL=INFO

# 前后端同源访问时 CORS 不参与；保留该项用于直接调 API 或未来接入反代。
# 将 43.132.156.72 替换为你的云服务器公网 IP 或域名。
CORS_ALLOW_ORIGINS=["http://43.132.156.72","http://43.132.156.72:80","http://43.132.156.72:19013","http://127.0.0.1:19013","http://localhost:19013"]
